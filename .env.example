# Connexion Postgres directe (Supabase > Project Settings > Database >
# Connection string > URI). Utilisée UNIQUEMENT au build pour créer les tables.
DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# API REST Supabase (Project Settings > API). Utilisée par les fonctions api/.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Slug de la page publique créée automatiquement (défaut : "contact")
PUBLIC_SLUG=contact

# Optionnel : géolocalisation approximative par IP (ex: ipapi.co)
IPGEO_API_KEY=
